# Public Supabase project URL used by server-side rendering and backend routes.
SUPABASE_URL=https://your-project-ref.supabase.co

# Public Supabase publishable key. This is safe to expose to the browser when RLS and storage policies are correct.
SUPABASE_PUBLISHABLE_KEY=your-public-supabase-publishable-key

# Private Supabase service-role key. Server-only; never expose to browser or Max.
SUPABASE_SERVICE_ROLE_KEY=your-private-supabase-service-role-key

# Custom shared secret for trusted Max worker routes. Server-only plus local Max config.
MAX_WORKER_SECRET=your-private-max-worker-secret

# Frontend-exposed Supabase config. VITE_* values are bundled into the website frontend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-supabase-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Public Supabase project identifier used by local tooling/config.
SUPABASE_PROJECT_ID=your-project-ref
